generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Auth (Better Auth)
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  profile  FiscalProfile?
  revenues  Revenue[]
  expenses  Expense[]
  alertLogs AlertLog[]
  clients   Client[]
  quotes    Quote[]
  invoices  Invoice[]
  accountantAccesses AccountantAccess[] @relation("AccountantUser")
  clientAccesses     AccountantAccess[] @relation("ClientUser")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==========================================
// Domain Models
// ==========================================

model FiscalProfile {
  id                   String               @id @default(cuid())
  userId               String               @unique
  activityType         ActivityType
  versementLiberatoire Boolean
  declarationFrequency DeclarationFrequency
  tvaAssujetti         Boolean              @default(false)
  acre                 Boolean              @default(false)
  acreDateDebut        DateTime?
  situationFamiliale   SituationFamiliale?
  enfantsACharge       Int                  @default(0)
  siret                String?
  address              String?
  ownerName            String?
  businessName         String?
  professionalEmail    String?
  phone                String?
  tvaNumber            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Revenue {
  id             String        @id @default(cuid())
  userId         String
  amount         Decimal       @db.Decimal(10, 2)
  month          Int
  year           Int
  description    String?
  activityType   ActivityType?
  attachmentUrl  String?
  attachmentName String?
  invoiceId      String?       @unique
  locked         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([userId, month, year])
  @@index([userId, year])
}

model Expense {
  id             String          @id @default(cuid())
  userId         String
  amount         Decimal         @db.Decimal(10, 2)
  category       ExpenseCategory
  label          String
  month          Int
  year           Int
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month, year])
}

model AlertLog {
  id        String     @id @default(cuid())
  userId    String
  alertType AlertType
  year      Int
  sentAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alertType, year])
  @@index([userId, year])
}

// ==========================================
// Clients & Invoicing
// ==========================================

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  siret     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes   Quote[]
  invoices Invoice[]

  @@index([userId])
}

model Quote {
  id                String      @id @default(cuid())
  userId            String
  clientId          String
  number            String
  status            QuoteStatus @default(DRAFT)
  notes             String?
  paymentTerms      String?
  paymentMethod     String?
  bankAccountHolder String?
  bankIban          String?
  bankBic           String?
  issuedAt          DateTime    @default(now())
  validUntil        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client         @relation(fields: [clientId], references: [id])
  lines   DocumentLine[]
  invoice Invoice?

  @@unique([userId, number])
  @@index([userId])
}

model Invoice {
  id                String        @id @default(cuid())
  userId            String
  clientId          String
  quoteId           String?       @unique
  parentInvoiceId   String?
  number            String
  status            InvoiceStatus @default(DRAFT)
  notes             String?
  paymentTerms      String?
  paymentMethod     String?
  bankAccountHolder String?
  bankIban          String?
  bankBic           String?
  issuedAt          DateTime      @default(now())
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id])
  quote         Quote?         @relation(fields: [quoteId], references: [id])
  parentInvoice Invoice?       @relation("CreditNotes", fields: [parentInvoiceId], references: [id])
  creditNotes   Invoice[]      @relation("CreditNotes")
  lines         DocumentLine[]
  revenue       Revenue?

  @@unique([userId, number])
  @@index([userId])
}

model DocumentLine {
  id          String   @id @default(cuid())
  quoteId     String?
  invoiceId   String?
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  vatRate     Decimal? @db.Decimal(5, 2)
  sortOrder   Int      @default(0)

  quote   Quote?   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ==========================================
// Enums
// ==========================================

enum ActivityType {
  BIC_VENTE
  BIC_PRESTATION
  BNC_LIBERAL_URSSAF
  BNC_LIBERAL_CIPAV
}

enum DeclarationFrequency {
  MENSUELLE
  TRIMESTRIELLE
}

enum SituationFamiliale {
  CELIBATAIRE
  EN_COUPLE
}

enum AlertType {
  SEUIL_75
  SEUIL_90
  SEUIL_100
  TVA_APPROCHE
  TVA_DEPASSE
}

enum ExpenseCategory {
  LOGICIEL
  TRANSPORT
  MATERIEL
  TELEPHONE
  BUREAU
  FORMATION
  ASSURANCE
  AUTRE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AccessStatus {
  PENDING
  ACTIVE
  REVOKED
}

model AccountantAccess {
  id           String       @id @default(cuid())
  accountantId String
  clientId     String
  status       AccessStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  accountant User @relation("AccountantUser", fields: [accountantId], references: [id], onDelete: Cascade)
  client     User @relation("ClientUser", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([accountantId, clientId])
  @@index([accountantId])
  @@index([clientId])
}
